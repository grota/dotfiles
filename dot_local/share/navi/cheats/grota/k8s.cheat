% kubernetes

# get pod yaml
kubectl get pod <podid> -o yaml | bat -l yaml

# pod describe
kubectl describe pod <podid>

# pod exec into shell
kubectl exec -it <podid> -- ash -il

# pod logs -f
kubectl logs -f <podid>

# create k8s job from cronjob
kubectl create job --from=cronjob/<cronjobname>

$ podid: kubectl get pods --- --headers 1 --column 1
$ cronjobname: kubectl get cronjobs --- --headers 1 --column 1

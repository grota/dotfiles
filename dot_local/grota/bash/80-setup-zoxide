# vim: set tabstop=2 shiftwidth=2 ft=bash foldmethod=marker:
eval "$(zoxide init bash)"

_fzf_complete_z() {
  FZF_COMPLETION_TRIGGER='' _fzf_complete --reverse --prompt="> " --bind=tab:down --bind=shift-tab:up -- "$@" < <(zoxide query --list)
}
complete -F _fzf_complete_z -o default -o bashdefault z
